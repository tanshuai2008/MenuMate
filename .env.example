# MenuMate Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to git — it is listed in .gitignore.

# Required: Google Gemini API Key
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Custom Search API (for inline real dish photos)
# Without these, the app falls back to Google Image Search links.
# Setup: https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here
